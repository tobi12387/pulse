{
  "name": "pulse",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["shared", "backend", "frontend"],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "check:migrations": "node scripts/check-migrations.mjs",
    "typecheck": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "test": "npm run test -w backend",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:webkit": "playwright install webkit",
    "qa:ux-evidence": "PULSE_ROUTE_EVIDENCE=true playwright test frontend/e2e/route-evidence.spec.ts --project=desktop-chromium --project=mobile-chromium",
    "qa:ux-evidence:iphone": "PULSE_ROUTE_EVIDENCE=true PULSE_E2E_WEBKIT=true playwright test frontend/e2e/route-evidence.spec.ts --project=desktop-chromium --project=iphone-webkit",
    "test:e2e:ui": "playwright test --ui",
    "test:scripts": "node --test scripts/*.test.mjs",
    "services:up": "bash scripts/dev-services.sh up",
    "services:down": "bash scripts/dev-services.sh down",
    "services:status": "bash scripts/dev-services.sh status",
    "verify:local": "bash scripts/verify-local.sh",
    "verify:local:no-services": "bash scripts/verify-local.sh --no-services",
    "verify:local:e2e": "bash scripts/verify-local.sh --with-e2e",
    "verify:server": "bash scripts/verify-server.sh",
    "pulse:status": "bash scripts/pulse-status.sh",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend"
  },
  "engines": {
    "node": ">=22"
  }
}
